# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://zentinelle:zentinelle@localhost:5432/zentinelle
POSTGRES_USER=zentinelle
POSTGRES_PASSWORD=zentinelle

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# open           — No login required, everyone is admin (internal/dev, behind VPN)
# local          — Built-in username/password with session cookies
# sso            — OIDC/SAML via external provider (Google, Okta, Cognito, etc.)
# standalone     — Alias for "local" (backward compat)
AUTH_MODE=open

# Bootstrap secret for agent registration tokens (standalone mode).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Tokens are issued as: bt_<tenant_id>_<HMAC-SHA256(secret, tenant_id)>
ZENTINELLE_BOOTSTRAP_SECRET=

# Required if AUTH_MODE=client_cove (see calliope.md — do not commit those values here)
# CALLIOPE_INTERNAL_API_URL=https://app.calliope.ai
# CALLIOPE_INTERNAL_API_KEY=
# CALLIOPE_TENANT_CACHE_TTL=300

# ── Encryption ────────────────────────────────────────────────────────────────
# Fernet key for secrets store encryption. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api/zentinelle
NEXT_PUBLIC_GQL_URL=http://localhost/gql/zentinelle

# ── Email (optional) ──────────────────────────────────────────────────────────
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@zentinelle.ai

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CSRF ──────────────────────────────────────────────────────────────────────
CSRF_TRUSTED_ORIGINS=http://localhost:3002,http://localhost:8080

# ── ClickHouse (optional — for high-volume analytics) ────────────────────────
# Leave unset for standalone. Enable with: docker compose --profile analytics up
# CLICKHOUSE_URL=clickhouse://default:@localhost:8123/default
