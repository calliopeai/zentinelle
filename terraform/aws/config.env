# -----------------------------------------------------------------------------
# Zentinelle — AWS Configuration
#
# Shared configuration for all environments. Sourced by run.sh and bootstrap.sh.
# Edit these values before running bootstrap.
# -----------------------------------------------------------------------------

# Project slug — used in all resource naming
PROJECT="zentinelle"

# AWS region — used for state backends and as the default provider region
AWS_REGION="us-west-2"

# Owner tag
OWNER="calliopeai"
